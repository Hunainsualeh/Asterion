# Secrets — holds live Groq/DeepSeek API keys. Never commit.
# Matches .env at any depth (root and backend/) but not .env.example.
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Agent-generated code. Written by tools/fs.py at runtime; each proj-*/repo is
# its own `git init` repo, so tracking these creates dangling gitlinks.
backend/workspace/

# Runtime state, not source: tasks/reminders and the embedding store.
# SQLite keeps -shm/-wal sidecars alongside the db in WAL mode.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Node / Next.js
node_modules/
.next/
out/
.vercel/
*.tsbuildinfo
next-env.d.ts

# Editors & OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
