# Copy relevant values into the project-root .env (D:\Asterion\.env)
# The Groq key may be named either GROQ_API_KEY or Asterion_Secret_key.

# ---- Groq (required) ----
# Up to 4 keys are pooled and rotated on rate-limit errors (see
# app/llm/groq_client.py). Extra keys are optional but strongly recommended -
# the free/on_demand tier's per-key limits are tight.
Asterion_Secret_key=gsk_your_key_here
Asterion_Secret_key1=gsk_your_second_key_here
Asterion_Secret_key2=gsk_your_third_key_here
Asterion_Secret_key3=gsk_your_fourth_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ---- DeepSeek (optional) ----
# Enables the DeepSeek models in Settings > Models. Without a key the picker
# still lists them, greyed out, and everything runs on Groq.
#
# DeepSeek is PREPAID. A key on a zero-balance account authenticates fine and
# still answers GET /models, but every completion comes back HTTP 402
# "Insufficient Balance". Asterion detects this (Settings > Models shows the
# balance) and falls back to Groq rather than failing the run. Top up at
# https://platform.deepseek.com/top_up
#
# May be named either DEEPSEEK_API_KEY or Deepseek_Key. Up to 3 are pooled.
Deepseek_Key=sk_your_key_here
# Deepseek_Key1=
# Deepseek_Key2=

# ---- Redis ----
# If this is unreachable the backend falls back to in-process fakeredis.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_NAMESPACE=asterion
ALLOW_FAKEREDIS=true

# ---- Server ----
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:3000
